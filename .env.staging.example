# Template for the staging host's real .env (never commit the filled-in
# version). Copy to .env on STAGING_HOST, fill in real values. Everything not
# listed here follows .env.example.

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Store the same value as the "staging" GitHub Environment's JWT_SECRET_KEY
# secret too — CD doesn't inject it into the host's .env for you (see
# DEPLOYMENT.md), it must already be there before the first deploy.
JWT_SECRET_KEY=

AUTH_DATABASE_URL=sqlite:///./data/auth.db

# --- LLM provider — same keys as .env.example, staging's own values ---
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_FAST_DEPLOYMENT=

# --- WhatsApp (Meta Cloud API) — see DEVSECOPS_PLAN.md section B ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
