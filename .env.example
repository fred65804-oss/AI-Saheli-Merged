# Copy to .env and fill in what you need. Nothing here is required to run
# the offline demo (keyword routing + lexicon safety work with zero keys).

# --- LLM provider (optional — omit to run fully offline) ---
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Auth ---
# REQUIRED for any real deployment: a long random secret used to sign JWTs.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# The code ships a dev default so signup/login work out of the box locally,
# but that default is public (it's in this repo) — anyone who knows it can
# forge access tokens, so never leave it in place outside a laptop demo.
JWT_SECRET_KEY=dev-insecure-secret-change-me-not-for-prod
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_DATABASE_URL=sqlite:///./data/auth.db
